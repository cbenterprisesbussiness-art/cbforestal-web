# ===========================================================================
# Variables de entorno de CB Forestal
# Copia este archivo como .env (en local) y configúralas también en Vercel.
# ===========================================================================

# --- API de contacto (api/contact.js) -------------------------------------
# API key de Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Remitente verificado en Resend (debe ser un dominio que tengas validado)
CONTACT_FROM_EMAIL=CB Forestal <noreply@cbforestal.es>

# Buzón que recibirá las consultas del formulario web
CONTACT_TO_EMAIL=info@cbforestal.es

# Datos de contacto que aparecen en el email de confirmación al cliente
CONTACT_PUBLIC_PHONE=+34 936 94 21 74
CONTACT_PUBLIC_EMAIL=info@cbforestal.es

# --- Tracking en el cliente (src/shared/tracking.js) ----------------------
# Solo se cargan si están definidas. Déjalas vacías hasta tener cuenta creada.
# Meta Pixel ID (Facebook / Instagram). Formato: 15-16 dígitos.
VITE_META_PIXEL_ID=

# Google Analytics 4 Measurement ID. Formato: G-XXXXXXX
VITE_GA4_ID=
